@page "/services"
@inject CargoExpress.Data.CargoService CargoService
@rendermode InteractiveServer
@using CargoExpress.Models

<PageTitle>Услуги — CargoExpress</PageTitle>

<div class="page-header text-center mb-4">
    <h2>📦 Наши услуги</h2>
    <p class="text-white-50">Выберите подходящий тип перевозки</p>
</div>

@if (services == null)
{
    <div class="text-center text-white">
        <div class="spinner-border" role="status"></div>
        <p class="mt-2">Загрузка...</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var service in services)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-icon-big">@service.Icon</div>
                    <div class="card-body">
                        <h5 class="card-title">@service.Name</h5>
                        <p class="card-text">@service.Description</p>
                        <p class="card-details text-muted small">@service.Details</p>
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <span class="card-price">от @service.BasePrice ₽</span>
                            <a href="/order" class="btn btn-primary btn-sm">Заказать</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="alert alert-light mt-4 text-center">
        <strong>Не нашли нужную услугу?</strong> Позвоните нам: <strong>+7 (495) 123-45-67</strong>
        — обсудим любой нестандартный запрос!
    </div>
}

@code {
    private List<Service>? services;

    protected override async Task OnInitializedAsync()
    {
        services = await CargoService.GetServicesAsync();
    }
}